---
import Base from "@/layouts/Base.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import handleDraftPage from "@/lib/utils/handleDraftPage";
import AboutTeaser from "@/components/sections/AboutTeaser.astro";
import AboutHistoryValues from "@/components/sections/AboutHistoryValues.astro";
import AboutBanner from "@/components/sections/AboutBanner.astro";
import OurTeam from "@/components/sections/OurTeam.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import { generatePaths } from "@/lib/utils/languageParser.ts";

export function getStaticPaths() {
  return generatePaths();
}

const entry = await getEntryCTM("about", "-index", Astro.currentLocale);

// Remove drafts pages in production (or dev when VITE_HIDE_DRAFTS_IN_DEV)
const response = handleDraftPage(entry?.data);
if (response) return response;

const { Content } = entry ? await entry.render() : { Content: null };
---

<Base {...entry?.data}>
  <AboutTeaser
    subtitle={entry?.data?.subtitle}
    title={entry?.data?.title}
    teaserImage={entry?.data?.teaser_image}
    teaserImageAlt={entry?.data?.teaser_image_alt}>
    {Content && <Content />}
  </AboutTeaser>
  <AboutHistoryValues />
  <AboutBanner content={{ show_heading: false }} />
  <OurTeam />
  <CallToAction />
</Base>
