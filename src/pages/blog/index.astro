---
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Group by tags
const tagMap = new Map<string, typeof allPosts>();
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    if (!tagMap.has(tag)) tagMap.set(tag, []);
    tagMap.get(tag)!.push(post);
  }
}

// All unique tags sorted
const allTags = Array.from(tagMap.keys()).sort();
---
<PageLayout title="Blog" description="Insights and perspectives from KSM Technology Partners on technology in utilities and life sciences.">

  <div class="page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Insights and perspectives on technology in utilities and life sciences.</p>
    </div>
  </div>

  <div class="section">

    <!-- All posts (most recent first) -->
    <div class="grid-3 mb-2">
      {allPosts.map(post => (
        <BlogCard
          title={post.data.title}
          excerpt={post.data.excerpt}
          slug={post.id.replace(/\.mdx?$/, '')}
          date={post.data.date}
          author={post.data.author}
          tags={post.data.tags}
        />
      ))}
    </div>

    <!-- Posts grouped by tag -->
    {allTags.map(tag => (
      <div>
        <h2 class="blog-group-heading">{tag}</h2>
        <div class="grid-3">
          {tagMap.get(tag)!.map(post => (
            <BlogCard
              title={post.data.title}
              excerpt={post.data.excerpt}
              slug={post.id.replace(/\.mdx?$/, '')}
              date={post.data.date}
              author={post.data.author}
              tags={post.data.tags}
            />
          ))}
        </div>
      </div>
    ))}

  </div>

</PageLayout>
