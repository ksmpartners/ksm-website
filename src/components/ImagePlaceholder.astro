---
interface Props {
  caption?: string;
  alt?: string;
}

const { caption, alt = 'Image placeholder' } = Astro.props;
---
<figure class="image-placeholder">
  <img src={`${import.meta.env.BASE_URL}images/placeholder.svg`} alt={alt} />
  {caption && <figcaption class="image-caption">{caption}</figcaption>}
</figure>
