---
interface Props {
  title: string;
  excerpt: string;
  slug: string;
  date: Date;
  author?: string;
  tags?: string[];
}

const { title, excerpt, slug, date, author = 'KSM Team', tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<article class="card">
  <div class="tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
  <h3>{title}</h3>
  <div class="card-meta">
    <time datetime={date.toISOString()}>{formattedDate}</time> &bull; {author}
  </div>
  <p>{excerpt}</p>
  <a href={`/blog/${slug}`} class="card-link">Read more →</a>
</article>
